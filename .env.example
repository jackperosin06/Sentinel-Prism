# Copy to .env locally (never commit .env). NFR3: no real secrets in repo.
#
# App (async): FastAPI / SQLAlchemy async — Story 1.3+.
DATABASE_URL=postgresql+asyncpg://sentinel:change-me-local-only@localhost:5432/sentinel_prism
#
# Migrations (sync): Alembic CLI uses psycopg3 — match POSTGRES_* / DATABASE_URL (placeholder only).
ALEMBIC_SYNC_URL=postgresql+psycopg://sentinel:change-me-local-only@localhost:5432/sentinel_prism

# JWT (Story 1.3) — use a long random secret locally; never commit real values (NFR3).
JWT_SECRET=change-me-generate-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Credential verifier for POST /auth/login (Story 1.5): local (default) | stub (dev/tests only).
AUTH_PROVIDER=local

# Optional: docker-compose Postgres (local dev)
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=sentinel_prism
