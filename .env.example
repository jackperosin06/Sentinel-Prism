# Copy to .env locally (never commit .env). NFR3: no real secrets in repo.
#
# FR41: This product does not perform automated binding regulatory submissions or external filings
# on behalf of users (decision-support only; see PRD).
#
# App (async): FastAPI / SQLAlchemy async — Story 1.3+.
DATABASE_URL=postgresql+asyncpg://sentinel:change-me-local-only@localhost:5432/sentinel_prism
#
# Migrations (sync): Alembic CLI uses psycopg3 — match POSTGRES_* / DATABASE_URL (placeholder only).
ALEMBIC_SYNC_URL=postgresql+psycopg://sentinel:change-me-local-only@localhost:5432/sentinel_prism

# JWT (Story 1.3) — use a long random secret locally; never commit real values (NFR3).
JWT_SECRET=change-me-generate-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Credential verifier for POST /auth/login (Story 1.5): local (default) | stub (dev/tests only).
AUTH_PROVIDER=local

# Briefing grouping (Story 4.3, FR18). JSON array of: date_bucket | jurisdiction | severity | topic.
# BRIEFING_GROUPING_DIMENSIONS=["date_bucket","jurisdiction","severity","topic"]
# BRIEFING_DATE_BUCKET=day

# Classification LLM: max LangGraph node attempts for transient failures (Story 3.6). Integer 2–10, default 3.
# SENTINEL_CLASSIFICATION_MAX_ATTEMPTS=3

# LangGraph pipeline checkpointer selection (Story 4.1, FR35).
# Unset (default): use Postgres when DATABASE_URL is non-empty, else in-memory.
# `memory`: always in-memory (tests / demos; no durable HITL resume).
# `postgres`: always Postgres (DATABASE_URL required; FastAPI lifespan calls
# `AsyncPostgresSaver.setup()` on startup which CREATEs LangGraph's checkpoint
# tables in DATABASE_URL — it is NOT tracked by Alembic. Point DATABASE_URL at
# the same database as ALEMBIC_SYNC_URL in production; in local dev you can
# set this to `memory` to suppress the DDL).
# PIPELINE_CHECKPOINTER=

# Optional public web search enrichment for classify (Story 3.7, NFR12). Default off — no Tavily calls.
# SENTINEL_WEB_SEARCH_ENABLED=0
# SENTINEL_WEB_SEARCH_MAX_RESULTS=5
# SENTINEL_TAVILY_TIMEOUT=20
# Prefer SENTINEL_TAVILY_API_KEY for this app; Tavily SDK also accepts TAVILY_API_KEY.
# SENTINEL_TAVILY_API_KEY=
# TAVILY_API_KEY=

# Optional: docker-compose Postgres (local dev)
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=sentinel_prism

# External notifications sandbox (Story 5.3 — FR25). Default: none (no outbound SMTP/Slack).
# NOTIFICATIONS_EXTERNAL_CHANNEL=none
# NOTIFICATIONS_EXTERNAL_CHANNEL=smtp
# NOTIFICATIONS_EXTERNAL_CHANNEL=slack
# NOTIFICATIONS_SMTP_HOST=sandbox.smtp.example.test
# NOTIFICATIONS_SMTP_PORT=587
# NOTIFICATIONS_SMTP_USER=placeholder
# NOTIFICATIONS_SMTP_PASSWORD=placeholder
# NOTIFICATIONS_SMTP_FROM=noreply@example.test
# NOTIFICATIONS_SMTP_USE_TLS=1
# NOTIFICATIONS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/placeholder

# Notification scheduling (Story 5.4 — FR22). Comma-separated severities for immediate in-app + external.
# NOTIFICATIONS_IMMEDIATE_SEVERITIES=critical,high
# NOTIFICATIONS_DIGEST_ENABLED=1
# NOTIFICATIONS_DIGEST_FLUSH_INTERVAL_SECONDS=900
# Cap applies per `node_route` invocation (all teams combined), not per team.
# Preferred key:
# NOTIFICATIONS_MAX_EXTERNAL_IMMEDIATE_PER_RUN=50
# Backward-compatible legacy key (still accepted):
# NOTIFICATIONS_MAX_EXTERNAL_IMMEDIATE_PER_ROUTE=50
# NOTIFICATIONS_DIGEST_FLUSH_BATCH_MAX=500
# Digest payloads include full item URLs in this MVP (may include query params).
# High-volume teams may receive multiple digest messages in one cadence window.
# `channel_slug` on digest rows is informational in Story 5.4 and is not part of
# digest idempotency keys yet.
