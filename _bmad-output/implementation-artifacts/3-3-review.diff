+            "errors": [
+                {
+                    "step": "scout",
+                    "message": "fallback_unexpected_error",
+                    "error_class": type(exc).__name__,
+                    "detail": str(exc),
+                    "fetch_path": "fallback",
+                }
+            ],
+        }
+    except Exception as exc:
+        logger.warning(
+            "graph_scout",
+            extra={
+                "event": "graph_scout_fetch_failed",
+                "ctx": {
+                    "run_id": run_id,
+                    "source_id": str(source_uuid),
