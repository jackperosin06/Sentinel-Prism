+            ],
+        }
+    except FallbackFetchUnexpectedError as wrapped:
+        exc = wrapped.cause
+        logger.warning(
+            "graph_scout",
+            extra={
+                "event": "graph_scout_fetch_failed",
+                "ctx": {
+                    "run_id": run_id,
+                    "source_id": str(source_uuid),
