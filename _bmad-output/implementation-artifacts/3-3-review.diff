+
+    source_type: SourceType = row.source_type
+    primary_url: str = row.primary_url
+    fallback_url: str | None = row.fallback_url
+    fallback_mode = row.fallback_mode
+
+    if source_type not in (SourceType.RSS, SourceType.HTTP):
+        logger.info(
